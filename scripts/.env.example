# Stellar Testnet — generado por setup-testnet.sh + deploy manual
# Copia como .env y completa los valores reales.

STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Clave admin (ver: stellar keys show cora-admin)
ADMIN_KEY_ALIAS=cora-admin

# Contratos desplegados en testnet
# Fase 2 (solo pool básico, sin claims)
# POOL_CONTRACT_ADDRESS=CBLLYA6MC5SNFHDQS4AAUOWEPL3NBNEMQ3H65GV6HU5PUAYZOYBF4M4Y

# Fase 3 — contrato completo con claims y validación multisig
POOL_CONTRACT_ADDRESS=CBN6ANOCARQHWOFOCZKFKBQ4PIIUGWDZ7VXAVV43IB6HOHTOUZNRPK4T

# Token USDC de prueba (Stellar Asset Contract)
USDC_CONTRACT_ADDRESS=CXXXXX_DEPLOY_PENDING
